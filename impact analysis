  const elev    = matched.filter(s => s.band === 'ELEVATED').length;
  const ben     = matched.filter(s => s.band === 'BENEFICIARY').length;
  const wAvg    = matched.reduce((a,s) => a + s.overall * s.userWt, 0).toFixed(2);
  const strip = document.getElementById('kpiStrip');
  strip.innerHTML = `
    <div class="kpi kpi-w"><div class="kpi-label">Wtd. Avg. Score</div><div class="kpi-val">${wAvg}</div><div class="kpi-sub">Out of 10 · Portfolio level</div></div>
    <div class="kpi kpi-r"><div class="kpi-label">Critical Positions</div><div class="kpi-val">${crit}</div><div class="kpi-sub">Score ≥ 7.0 overall</div></div>
    <div class="kpi kpi-a"><div class="kpi-label">Elevated Positions</div><div class="kpi-val">${elev}</div><div class="kpi-sub">Score 5.0–6.9</div></div>
    <div class="kpi kpi-g"><div class="kpi-label">Beneficiaries</div><div class="kpi-val">${ben}</div><div class="kpi-sub">Net positive outlook</div></div>
    <div class="kpi kpi-b"><div class="kpi-label">Holdings Analysed</div><div class="kpi-val">${total}</div><div class="kpi-sub">${unmatched.length} not matched</div></div>
  `;

  // Distribution bar chart
  const bands = ['CRITICAL','ELEVATED','NEUTRAL','LOW RISK','BENEFICIARY'];
  const bandCols = {'CRITICAL':'#C0392B','ELEVATED':'#D4860A','NEUTRAL':'#888','LOW RISK':'#1A8C4E','BENEFICIARY':'#1A5276'};
  const dist = document.getElementById('distBars');
  dist.innerHTML = bands.map(b => {
    const cnt = matched.filter(s=>s.band===b).length;
    const pct = total ? Math.round(cnt/total*100) : 0;
    return `<div class="dist-row">
      <div class="dist-label" style="color:${bandCols[b]};font-weight:700">${b}</div>
      <div class="dist-track"><div class="dist-bar" style="width:${Math.max(pct,4)}%;background:${bandCols[b]}60"><span>${pct}%</span></div></div>
      <div class="dist-count" style="color:${bandCols[b]}">${cnt}</div>
    </div>`;
  }).join('');

  // Donut (SVG)
  const donut = document.getElementById('donutWrap');
  const bandData = bands.map(b => ({b, cnt: matched.filter(s=>s.band===b).length, col: bandCols[b]}));
  const cx=60, cy=60, r=48, iR=28;
  let cum=0;
  const segs = bandData.map(d => {
    const frac = total ? d.cnt/total : 0;
    const start=cum, end=cum+frac*360;
    cum=end;
    const s1 = polarToXY(cx,cy,r,start), s2 = polarToXY(cx,cy,r,end);
    const i1 = polarToXY(cx,cy,iR,start), i2 = polarToXY(cx,cy,iR,end);
    const lg = frac > 0.5 ? 1 : 0;
    return frac > 0 ? `<path d="M${s1.x},${s1.y} A${r},${r},0,${lg},1,${s2.x},${s2.y} L${i2.x},${i2.y} A${iR},${iR},0,${lg},0,${i1.x},${i1.y} Z" fill="${d.col}" opacity="0.85"/>` : '';
  }).join('');
  donut.innerHTML = `
    <svg width="120" height="120" viewBox="0 0 120 120">${segs}<circle cx="${cx}" cy="${cy}" r="${iR-2}" fill="var(--bg2)"/><text x="${cx}" y="${cy+5}" text-anchor="middle" fill="var(--gold)" font-size="13" font-weight="bold">${total}</text></svg>
    <div class="donut-legend">${bandData.map(d=>`<div class="dl-item"><div class="dl-dot" style="background:${d.col}"></div><span style="color:${d.col};font-weight:700">${d.b}</span> <span style="color:var(--text2);margin-left:4px">(${d.cnt})</span></div>`).join('')}</div>
  `;

  // Table
  renderTable(matched, 'ALL');

  // Unmatched
  if(unmatched.length > 0) {
    document.getElementById('unmatched-section').style.display = 'block';
    document.getElementById('unmatchedCount').textContent = unmatched.length;
    document.getElementById('unmatchedChips').innerHTML = unmatched.map(t=>`<span class="uchip">${t}</span>`).join('');
  } else document.getElementById('unmatched-section').style.display = 'none';

  // Reset filter
  document.querySelectorAll('.filt').forEach(f => f.classList.remove('active'));
  document.querySelector('.f-all').classList.add('active');
}

function polarToXY(cx,cy,r,deg) {
  const rad = (deg-90) * Math.PI/180;
  return {x: cx + r*Math.cos(rad), y: cy + r*Math.sin(rad)};
}

let currentFilter = 'ALL';
function filterTable(band, el) {
  currentFilter = band;
  document.querySelectorAll('.filt').forEach(f=>f.classList.remove('active'));
  el.classList.add('active');
  renderTable(analysedData, band);
}

function renderTable(data, filter) {
  const filtered = filter === 'ALL' ? data : data.filter(s => s.band === filter);
  const tbody = document.getElementById('resultsBody');
  tbody.innerHTML = filtered.map((s, i) => {
    const wtPct = (s.userWt * 100).toFixed(1);
    const wtBarW = Math.round(s.userWt * 100 * 4); // scale
    const sc = v => {
      const cls = v>=8?'sc-c':v>=5?'sc-e':v<=3?'sc-l':'sc-e';
      return `<span class="score-cell ${cls}">${v}</span>`;
    };
    const ov = s.overall;
    const ovCls = ov>=7?'sc-c':ov>=5?'sc-e':ov<3.5?'sc-l':'sc-v';
    const bpCls = {'CRITICAL':'bp-crit','ELEVATED':'bp-elev','NEUTRAL':'bp-neu','LOW RISK':'bp-low','BENEFICIARY':'bp-ben'}[s.band]||'bp-neu';
    const clsCls = {'AT RISK':'bp-at','NEUTRAL':'bp-nt','BENEFICIARY':'bp-bf'}[s.classification]||'bp-nt';
    return `<tr>
      <td style="color:#667;font-size:11px">${i+1}</td>
      <td class="ticker-cell">${s.symbol}</td>
      <td style="font-size:12px">${s.name}</td>
      <td style="font-size:11px;color:var(--text2)">${s.industry}</td>
      <td class="c">
        <div class="wt-bar">
          <div class="wt-track"><div class="wt-fill" style="width:${Math.min(wtBarW,50)}px;background:var(--gold);opacity:0.6"></div></div>
          <span style="font-size:11px;color:var(--text2)">${wtPct}%</span>
        </div>
      </td>
      <td class="c">${sc(s.f1)}</td>
      <td class="c">${sc(s.f2)}</td>
      <td class="c">${sc(s.f3)}</td>
      <td class="c"><span class="score-cell ${ovCls}" style="width:42px">${ov.toFixed(1)}</span></td>
      <td class="c"><span class="band-pill ${bpCls}">${s.band}</span></td>
      <td class="c"><span class="band-pill ${clsCls}">${s.classification}</span></td>
      <td class="note-cell">${s.note}</td>
    </tr>`;
  }).join('') || `<tr><td colspan="12" style="text-align:center;padding:24px;color:var(--text2)">No holdings match this filter.</td></tr>`;
}

// ── DOWNLOAD EXCEL ───────────────────────────────────────────────
function downloadExcel() {
  const wb2 = XLSX.utils.book_new();

  // Sheet 1: Summary
  const sumData = [
    ['IRAN / OIL CONFLICT — PORTFOLIO EXPOSURE REPORT', '', '', '', '', '', '', '', '', '', ''],
    ['Generated:', new Date().toLocaleDateString('en-IN'), '', 'Analysis Date:', 'March 31, 2026', '', '', '', '', '', ''],
    [''],
    ['PORTFOLIO SUMMARY', '', '', '', '', '', '', '', '', '', ''],
    ['Total Holdings Analysed:', analysedData.length, '', 'Unmatched Tickers:', portfolioData.unmatched.length, '', '', '', '', '', ''],
    ['Weighted Avg. Score:', parseFloat(analysedData.reduce((a,s)=>a+s.overall*s.userWt,0).toFixed(2)), '', 'Critical Positions:', analysedData.filter(s=>s.band==='CRITICAL').length, '', '', '', '', '', ''],
    ['Beneficiary Positions:', analysedData.filter(s=>s.band==='BENEFICIARY').length, '', 'Elevated Positions:', analysedData.filter(s=>s.band==='ELEVATED').length, '', '', '', '', '', ''],
    [''],
  ];
  const sumWs = XLSX.utils.aoa_to_sheet(sumData);
  XLSX.utils.book_append_sheet(wb2, sumWs, 'Summary');

  // Sheet 2: Full Analysis
  const headers = ['Rank','Symbol','Company Name','Industry','Weight %','F1 Direct Energy','F2 Supply Chain','F3 Macro/Consumer','Overall Score','Risk Band','Classification','Key Risk / Opportunity'];
  const rows2 = [headers, ...analysedData.map((s,i) => [
    i+1, s.symbol, s.name, s.industry,
    parseFloat((s.userWt*100).toFixed(2)),
    s.f1, s.f2, s.f3, s.overall,
    s.band, s.classification, s.note
  ])];
  const ws2 = XLSX.utils.aoa_to_sheet(rows2);
  ws2['!cols'] = [5,12,35,25,10,14,14,14,12,14,16,60].map(w=>({wch:w}));
  XLSX.utils.book_append_sheet(wb2, ws2, 'Full Analysis');

  // Sheet 3: Beneficiaries
  const benRows = [headers, ...analysedData.filter(s=>s.band==='BENEFICIARY').map((s,i) => [i+1, s.symbol, s.name, s.industry, parseFloat((s.userWt*100).toFixed(2)), s.f1, s.f2, s.f3, s.overall, s.band, s.classification, s.note])];
  const ws3 = XLSX.utils.aoa_to_sheet(benRows);
  ws3['!cols'] = ws2['!cols'];
  XLSX.utils.book_append_sheet(wb2, ws3, 'Beneficiaries');

  // Sheet 4: At Risk
  const riskRows = [headers, ...analysedData.filter(s=>s.band==='CRITICAL'||s.band==='ELEVATED').map((s,i) => [i+1, s.symbol, s.name, s.industry, parseFloat((s.userWt*100).toFixed(2)), s.f1, s.f2, s.f3, s.overall, s.band, s.classification, s.note])];
  const ws4 = XLSX.utils.aoa_to_sheet(riskRows);
  ws4['!cols'] = ws2['!cols'];
  XLSX.utils.book_append_sheet(wb2, ws4, 'Critical & Elevated');

  // Sheet 5: Unmatched
  if(portfolioData.unmatched.length > 0) {
    const umRows = [['Unmatched Tickers (Not Found in Nifty 500 DB)'], ...portfolioData.unmatched.map(t=>[t])];
    XLSX.utils.book_append_sheet(wb2, XLSX.utils.aoa_to_sheet(umRows), 'Unmatched Tickers');
  }

  XLSX.writeFile(wb2, 'Portfolio_Iran_Oil_Exposure_' + new Date().toISOString().slice(0,10) + '.xlsx');
}

function resetTool() {
  document.getElementById('results').style.display = 'none';
  document.getElementById('fileInput').value = '';
  analysedData = []; portfolioData = [];
  window.scrollTo({top:0, behavior:'smooth'});
}
