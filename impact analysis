// ── FILE HANDLER ─────────────────────────────────────────────────
function handleFile(file) {
  if (!file) return;
  document.getElementById('loading').style.display = 'block';
  document.getElementById('results').style.display = 'none';
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const wb = XLSX.read(e.target.result, {type:'binary'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, {defval:''});
      processPortfolio(rows);
    } catch(err) {
      alert('Error reading file: ' + err.message + '\nPlease ensure it is a valid .xlsx file.');
      document.getElementById('loading').style.display = 'none';
    }
  };
  reader.readAsBinaryString(file);
}

// ── PROCESS PORTFOLIO ────────────────────────────────────────────
function processPortfolio(rows) {
  // Find column names (case-insensitive)
  const sample = rows[0] || {};
  const keys = Object.keys(sample);
  const symKey = keys.find(k => k.toLowerCase().replace(/\s/g,'') === 'symbol') || keys[0];
  const wtKey  = keys.find(k => k.toLowerCase().replace(/\s/g,'').includes('weight') || k.toLowerCase() === 'wt' || k.toLowerCase() === 'wt%');

  const matched   = [];
  const unmatched = [];
  let totalWt = 0;

  rows.forEach(row => {
    const sym = String(row[symKey] || '').trim().toUpperCase();
    if(!sym) return;
    const wt = wtKey ? parseFloat(row[wtKey]) || 0 : 0;
    if(wt > 0) totalWt += wt;
    const dbEntry = DBMAP[sym];
    if(dbEntry) matched.push({...dbEntry, userWt: wt});
    else if(sym) unmatched.push(sym);
  });

  // Equal weight if no weights provided
  const useEqualWt = totalWt === 0;
  if(useEqualWt) matched.forEach(s => s.userWt = 1/matched.length);
  else {
    // Normalize if weights don't sum to ~1
    if(totalWt < 0.5) {
      // weights might be percentages (e.g. 15 instead of 0.15)
      if(totalWt > 5) matched.forEach(s => s.userWt = s.userWt/100);
    }
    const wSum = matched.reduce((a,s) => a + s.userWt, 0);
    if(wSum > 0) matched.forEach(s => s.userWt = s.userWt/wSum);
  }

  analysedData = matched.sort((a,b) => b.overall - a.overall);
  portfolioData = {matched, unmatched, useEqualWt};

  document.getElementById('loading').style.display = 'none';
  renderResults(matched, unmatched);
}

