<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Iran/Oil Conflict — Portfolio Exposure Analyser | Nifty 500</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  :root {
    --bg:     #07111E;
    --bg2:    #0D1B2A;
    --bg3:    #122035;
    --card:   #0F2236;
    --gold:   #C9A227;
    --gold2:  #E8C567;
    --red:    #C0392B;
    --amber:  #D4860A;
    --green:  #1A8C4E;
    --blue:   #1A5276;
    --text:   #E8EEF4;
    --text2:  #9BB0C8;
    --border: rgba(201,162,39,0.20);
    --red-l:  rgba(192,57,43,0.12);
    --amb-l:  rgba(212,134,10,0.12);
    --grn-l:  rgba(26,140,78,0.12);
    --blu-l:  rgba(26,82,118,0.12);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:'Segoe UI',Arial,sans-serif; min-height:100vh; }

  /* ── NAV ── */
  nav { background:linear-gradient(90deg,#050D18,#0D1B2A,#050D18);
    border-bottom:2px solid var(--gold); padding:0 32px; display:flex;
    align-items:center; justify-content:space-between; height:58px; position:sticky; top:0; z-index:100; }
  nav .logo { display:flex; align-items:center; gap:12px; }
  nav .logo span { font-size:15px; font-weight:800; color:var(--gold); letter-spacing:0.5px; }
  nav .logo sub { font-size:10px; color:var(--text2); display:block; font-weight:400; letter-spacing:0; }
  .nav-badge { background:rgba(192,57,43,0.2); border:1px solid var(--red);
    color:#FF6B5B; padding:4px 14px; border-radius:20px; font-size:11px; font-weight:700; letter-spacing:0.8px; }

  /* ── HERO ── */
  .hero { background:linear-gradient(135deg,#050E1C 0%,#0D2035 40%,#071218 100%);
    border-bottom:1px solid var(--border); padding:52px 48px 44px; text-align:center; position:relative; overflow:hidden; }
  .hero::before { content:''; position:absolute; top:-40px; left:50%; transform:translateX(-50%);
    width:600px; height:300px; background:radial-gradient(ellipse,rgba(201,162,39,0.07),transparent 70%); pointer-events:none; }
  .hero h1 { font-size:32px; font-weight:900; color:var(--gold); line-height:1.2; letter-spacing:0.5px; margin-bottom:10px; }
  .hero p { font-size:15px; color:var(--text2); max-width:680px; margin:0 auto 28px; line-height:1.6; }
  .hero .badges { display:flex; justify-content:center; gap:12px; flex-wrap:wrap; }
  .hbadge { padding:5px 16px; border-radius:20px; font-size:11px; font-weight:700; letter-spacing:0.8px; }
  .hb-r { background:var(--red-l); border:1px solid rgba(192,57,43,0.5); color:#FF6B5B; }
  .hb-a { background:var(--amb-l); border:1px solid rgba(212,134,10,0.5); color:#F0A030; }
  .hb-g { background:var(--grn-l); border:1px solid rgba(26,140,78,0.5); color:#3CC87A; }
  .hb-b { background:var(--blu-l); border:1px solid rgba(26,82,118,0.5); color:#7FB3D3; }

  /* ── MAIN LAYOUT ── */
  .main { max-width:1400px; margin:0 auto; padding:36px 32px; }

  /* ── HOW IT WORKS ── */
  .steps { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:36px; }
  .step { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:20px;
    display:flex; align-items:flex-start; gap:14px; }
  .step-num { width:34px; height:34px; border-radius:50%; background:var(--gold);
    color:#000; font-weight:900; font-size:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .step-text h3 { font-size:13px; font-weight:700; color:var(--gold2); margin-bottom:4px; }
  .step-text p { font-size:12px; color:var(--text2); line-height:1.5; }

  /* ── UPLOAD ZONE ── */
  .upload-section { background:var(--card); border:2px dashed var(--gold); border-radius:16px;
    padding:48px; text-align:center; cursor:pointer; transition:all 0.2s; margin-bottom:32px; position:relative; }
  .upload-section:hover, .upload-section.drag { border-color:var(--gold2); background:rgba(201,162,39,0.04); }
  .upload-section.drag { transform:scale(1.01); }
  .upload-icon { font-size:48px; margin-bottom:16px; }
  .upload-section h2 { font-size:20px; font-weight:700; color:var(--gold); margin-bottom:8px; }
  .upload-section p { color:var(--text2); font-size:14px; margin-bottom:20px; }
  .upload-section input[type=file] { display:none; }
  .btn { display:inline-flex; align-items:center; gap:8px; padding:12px 28px; border-radius:8px;
    font-size:14px; font-weight:700; cursor:pointer; border:none; transition:all 0.2s; letter-spacing:0.3px; }
  .btn-gold { background:linear-gradient(135deg,#C9A227,#E8C567); color:#000; }
  .btn-gold:hover { background:linear-gradient(135deg,#E8C567,#C9A227); transform:translateY(-1px); box-shadow:0 4px 16px rgba(201,162,39,0.4); }
  .btn-green { background:linear-gradient(135deg,#1A8C4E,#27AE60); color:#fff; }
  .btn-green:hover { background:linear-gradient(135deg,#27AE60,#1A8C4E); transform:translateY(-1px); }
  .btn-outline { background:transparent; color:var(--gold); border:1px solid var(--gold); }
  .btn-outline:hover { background:rgba(201,162,39,0.08); }
  .hint { font-size:12px; color:var(--text2); margin-top:14px; opacity:0.8; }

  /* ── LOADING ── */
  #loading { display:none; padding:32px; text-align:center; }
  .spinner { width:40px; height:40px; border:3px solid rgba(201,162,39,0.2);
    border-top-color:var(--gold); border-radius:50%; animation:spin 0.8s linear infinite; margin:0 auto 12px; }
  @keyframes spin { to { transform:rotate(360deg); } }

  /* ── RESULTS ── */
  #results { display:none; }
  .results-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
  .results-header h2 { font-size:20px; font-weight:800; color:var(--gold); }
  .actions { display:flex; gap:10px; flex-wrap:wrap; }

  /* ── KPI STRIP ── */
  .kpi-strip { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; margin-bottom:28px; }
  .kpi { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:16px 18px; position:relative; overflow:hidden; }
  .kpi::after { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
  .kpi.kpi-a::after { background:var(--amber); }
  .kpi.kpi-r::after { background:var(--red); }
  .kpi.kpi-g::after { background:var(--green); }
  .kpi.kpi-b::after { background:var(--blue); }
  .kpi.kpi-w::after { background:var(--gold); }
  .kpi-label { font-size:10px; font-weight:700; color:var(--text2); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:6px; }
  .kpi-val { font-size:26px; font-weight:900; font-variant-numeric:tabular-nums; }
  .kpi-sub { font-size:10px; color:var(--text2); margin-top:3px; }
  .kpi-r .kpi-val { color:#FF6B5B; }
  .kpi-a .kpi-val { color:#F0A030; }
  .kpi-g .kpi-val { color:#3CC87A; }
  .kpi-b .kpi-val { color:#7FB3D3; }
  .kpi-w .kpi-val { color:var(--gold2); }

  /* ── FILTER BAR ── */
  .filter-bar { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:20px; align-items:center; }
  .filter-bar span { font-size:12px; color:var(--text2); font-weight:600; }
  .filt { padding:5px 14px; border-radius:20px; font-size:11px; font-weight:700; cursor:pointer;
    border:1px solid var(--border); background:transparent; color:var(--text2); transition:all 0.15s; }
  .filt:hover, .filt.active { border-color:var(--gold); color:var(--gold); background:rgba(201,162,39,0.08); }
  .filt.f-all.active { border-color:var(--gold); color:var(--gold); }
  .filt.f-crit.active { border-color:var(--red); color:#FF6B5B; background:var(--red-l); }
  .filt.f-elev.active { border-color:var(--amber); color:#F0A030; background:var(--amb-l); }
  .filt.f-neu.active { border-color:#888; color:#aaa; background:rgba(100,100,100,0.1); }
  .filt.f-low.active { border-color:var(--green); color:#3CC87A; background:var(--grn-l); }
  .filt.f-ben.active { border-color:var(--blue); color:#7FB3D3; background:var(--blu-l); }

  /* ── TABLE ── */
  .table-wrap { overflow-x:auto; border:1px solid var(--border); border-radius:12px; }
  table { width:100%; border-collapse:collapse; font-size:12.5px; }
  thead tr { background:var(--bg2); }
  thead th { padding:11px 12px; text-align:left; font-size:10px; font-weight:700; color:var(--gold2);
    text-transform:uppercase; letter-spacing:0.7px; border-bottom:1px solid var(--border); white-space:nowrap; }
  thead th.c { text-align:center; }
  tbody tr { border-bottom:1px solid rgba(255,255,255,0.04); transition:background 0.1s; }
  tbody tr:last-child { border-bottom:none; }
  tbody tr:nth-child(odd) { background:rgba(255,255,255,0.015); }
  tbody tr:hover { background:rgba(201,162,39,0.04); }
  tbody td { padding:9px 12px; vertical-align:middle; }
  tbody td.c { text-align:center; }

  .score-cell { display:inline-flex; align-items:center; justify-content:center;
    width:36px; height:24px; border-radius:6px; font-weight:800; font-size:13px; }
  .sc-c { background:rgba(192,57,43,0.8); color:#fff; }
  .sc-e { background:rgba(212,134,10,0.8); color:#fff; }
  .sc-l { background:rgba(26,140,78,0.8); color:#fff; }
  .sc-v { background:rgba(26,82,118,0.8); color:#fff; }

  .band-pill { display:inline-block; padding:2px 10px; border-radius:12px; font-size:10px; font-weight:800; letter-spacing:0.5px; }
  .bp-crit { background:rgba(192,57,43,0.18); color:#FF6B5B; border:1px solid rgba(192,57,43,0.4); }
  .bp-elev { background:rgba(212,134,10,0.18); color:#F0A030; border:1px solid rgba(212,134,10,0.4); }
  .bp-neu  { background:rgba(80,80,80,0.18); color:#aaa; border:1px solid rgba(120,120,120,0.4); }
  .bp-low  { background:rgba(26,140,78,0.18); color:#3CC87A; border:1px solid rgba(26,140,78,0.4); }
  .bp-ben  { background:rgba(26,82,118,0.18); color:#7FB3D3; border:1px solid rgba(26,82,118,0.4); }
  .bp-at   { background:rgba(192,57,43,0.12); color:#FF8070; border:1px solid rgba(192,57,43,0.3); }
  .bp-nt   { background:rgba(80,80,80,0.12); color:#aaa; border:1px solid rgba(120,120,120,0.3); }
  .bp-bf   { background:rgba(26,140,78,0.12); color:#3CC87A; border:1px solid rgba(26,140,78,0.3); }

  .ticker-cell { font-family:'Courier New',monospace; font-weight:700; font-size:12px; color:var(--gold2); }
  .note-cell { font-size:11px; color:var(--text2); max-width:280px; line-height:1.4; }
  .unmatched { color:#777; font-style:italic; font-size:11px; }

  .not-found-row td { color:#667; font-size:11px; }
  .not-found-row .ticker-cell { color:#667; }

  /* ── PORTFOLIO WEIGHT BAR ── */
  .wt-bar { display:flex; align-items:center; gap:6px; }
  .wt-track { width:50px; height:6px; background:rgba(255,255,255,0.08); border-radius:3px; }
  .wt-fill { height:100%; border-radius:3px; }

  /* ── SUMMARY CHART (CSS only) ── */
  .sector-chart { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:28px; }
  .chart-box { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:18px; }
  .chart-title { font-size:11px; font-weight:700; color:var(--gold); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:14px; }
  .dist-bars { display:flex; flex-direction:column; gap:8px; }
  .dist-row { display:flex; align-items:center; gap:10px; }
  .dist-label { font-size:11px; color:var(--text2); width:90px; flex-shrink:0; }
  .dist-track { flex:1; height:16px; background:rgba(255,255,255,0.06); border-radius:4px; overflow:hidden; }
  .dist-bar { height:100%; border-radius:4px; display:flex; align-items:center; justify-content:flex-end; padding-right:6px; min-width:24px; }
  .dist-bar span { font-size:10px; font-weight:700; color:#fff; }
  .dist-count { font-size:11px; font-weight:700; width:24px; text-align:right; }

  /* ── DONUT (SVG) ── */
  .donut-wrap { display:flex; align-items:center; gap:20px; justify-content:center; }
  .donut-legend { display:flex; flex-direction:column; gap:8px; }
  .dl-item { display:flex; align-items:center; gap:8px; font-size:11px; }
  .dl-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

  /* ── UNMATCHED ── */
  #unmatched-section { margin-top:24px; }
  .unmatched-box { background:rgba(212,134,10,0.06); border:1px solid rgba(212,134,10,0.25);
    border-radius:10px; padding:16px 18px; }
  .unmatched-box h3 { font-size:12px; font-weight:700; color:#F0A030; margin-bottom:8px; }
  .unmatched-chips { display:flex; flex-wrap:wrap; gap:6px; }
  .uchip { background:rgba(212,134,10,0.1); border:1px solid rgba(212,134,10,0.3);
    color:#F0A030; padding:3px 10px; border-radius:12px; font-size:11px; font-family:monospace; }

  /* ── SAMPLE FORMAT ── */
  .format-box { background:rgba(26,82,118,0.08); border:1px solid rgba(26,82,118,0.3);
    border-radius:10px; padding:16px 18px; margin-top:16px; }
  .format-box h3 { font-size:12px; font-weight:700; color:#7FB3D3; margin-bottom:10px; }
  .format-table { width:100%; border-collapse:collapse; font-size:12px; }
  .format-table th { background:rgba(26,82,118,0.2); color:#7FB3D3; padding:6px 10px; text-align:left; font-size:10px; letter-spacing:0.5px; }
  .format-table td { padding:5px 10px; color:var(--text2); border-bottom:1px solid rgba(255,255,255,0.05); font-family:monospace; }

  /* ── FOOTER ── */
  footer { border-top:1px solid var(--border); padding:20px 32px; text-align:center; }
  footer p { font-size:11px; color:var(--text2); opacity:0.7; }
  footer a { color:var(--gold); text-decoration:none; }

  /* ── RESPONSIVE ── */
  @media(max-width:900px) {
    .hero { padding:32px 20px; }
    .hero h1 { font-size:22px; }
    .main { padding:20px 16px; }
    .steps { grid-template-columns:1fr; }
    .kpi-strip { grid-template-columns:repeat(2,1fr); }
    .sector-chart { grid-template-columns:1fr; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">
    <svg width="32" height="32" viewBox="0 0 32 32"><circle cx="16" cy="16" r="16" fill="#C9A227" opacity="0.15"/><text x="16" y="21" text-anchor="middle" fill="#C9A227" font-size="14" font-weight="900">⚑</text></svg>
    <div>
      <span>IRAN / OIL RISK ANALYSER</span>
      <sub>Nifty 500 · Three Cascade Layers · March 2026</sub>
    </div>
  </div>
  <div class="nav-badge">🔴 HORMUZ DISRUPTED · BRENT $110+</div>
</nav>

<!-- HERO -->
<section class="hero">
  <h1>Iran / Oil Conflict<br>Portfolio Exposure Analyser</h1>
  <p>Upload your equity portfolio in Excel format. Our engine cross-references every holding against our Nifty 500 Iran/Oil shock database — scored across three cascade layers — and delivers an instant downloadable risk heat map.</p>
  <div class="badges">
    <span class="hbadge hb-r">🔴 CRITICAL — Direct Energy Impact</span>
    <span class="hbadge hb-a">🟠 ELEVATED — Supply Chain Hit</span>
    <span class="hbadge hb-g">🟢 BENEFICIARY — Net Positive</span>
    <span class="hbadge hb-b">🔵 500 Nifty Stocks Covered</span>
  </div>
</section>

<!-- MAIN -->
<div class="main">

  <!-- HOW IT WORKS -->
  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-text">
        <h3>Prepare Your Portfolio</h3>
        <p>An Excel file (.xlsx) with a column named <b>Symbol</b> (NSE ticker) and optionally a <b>Weight</b> column (e.g. 0.15 for 15%). See the sample format below.</p>
      </div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-text">
        <h3>Upload & Analyse</h3>
        <p>Drop your file in the upload zone. The entire analysis runs <b>in your browser</b> — your data never leaves your device. Results appear instantly.</p>
      </div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-text">
        <h3>Download Heat Map</h3>
        <p>Get a colour-coded Excel heat map of your portfolio's exposure across First-Order, Second-Order, and Third-Order cascade channels.</p>
      </div>
    </div>
  </div>

  <!-- SAMPLE FORMAT -->
  <div class="format-box" style="margin-bottom:24px;">
    <h3>📋 Expected Excel Format (any sheet, first sheet used)</h3>
    <table class="format-table">
      <thead><tr><th>Symbol</th><th>Weight (optional)</th><th>Company Name (optional)</th></tr></thead>
      <tbody>
        <tr><td>RELIANCE</td><td>0.15</td><td>Reliance Industries Ltd.</td></tr>
        <tr><td>TCS</td><td>0.12</td><td>Tata Consultancy Services</td></tr>
        <tr><td>HDFCBANK</td><td>0.10</td><td>HDFC Bank Ltd.</td></tr>
        <tr><td>INFY</td><td>0.08</td><td>Infosys Ltd.</td></tr>
      </tbody>
    </table>
    <p style="font-size:11px;color:var(--text2);margin-top:8px;">The <b>Symbol</b> column must match NSE ticker symbols (e.g. RELIANCE, TCS, HDFCBANK). Column header is case-insensitive. Weight column is optional — if missing, equal weights are assumed.</p>
  </div>

  <!-- UPLOAD ZONE -->
  <div class="upload-section" id="dropZone" onclick="document.getElementById('fileInput').click()">
    <div class="upload-icon">📊</div>
    <h2>Drop your portfolio Excel here</h2>
    <p>or click to browse — supports .xlsx and .xls files</p>
    <button class="btn btn-gold" onclick="event.stopPropagation();document.getElementById('fileInput').click()">
      📁 Choose Excel File
    </button>
    <input type="file" id="fileInput" accept=".xlsx,.xls" onchange="handleFile(this.files[0])">
    <div class="hint">🔒 100% private — all processing happens in your browser. No data is uploaded to any server.</div>
  </div>

  <!-- LOADING -->
  <div id="loading">
    <div class="spinner"></div>
    <p style="color:var(--text2);">Analysing your portfolio…</p>
  </div>

  <!-- RESULTS -->
  <div id="results">
    <div class="results-header">
      <h2>📊 Portfolio Exposure Analysis</h2>
      <div class="actions">
        <button class="btn btn-outline" onclick="resetTool()">↩ Upload New File</button>
        <button class="btn btn-green" onclick="downloadExcel()" id="downloadBtn">⬇ Download Excel Report</button>
      </div>
    </div>

    <!-- KPI Strip -->
    <div class="kpi-strip" id="kpiStrip"></div>

    <!-- Charts -->
    <div class="sector-chart">
      <div class="chart-box">
        <div class="chart-title">Portfolio Risk Distribution</div>
        <div class="dist-bars" id="distBars"></div>
      </div>
      <div class="chart-box">
        <div class="chart-title">Exposure by Classification</div>
        <div class="donut-wrap" id="donutWrap"></div>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
      <span>Filter:</span>
      <button class="filt f-all active" onclick="filterTable('ALL',this)">All</button>
      <button class="filt f-crit" onclick="filterTable('CRITICAL',this)">🔴 Critical</button>
      <button class="filt f-elev" onclick="filterTable('ELEVATED',this)">🟠 Elevated</button>
      <button class="filt f-neu" onclick="filterTable('NEUTRAL',this)">⚫ Neutral</button>
      <button class="filt f-low" onclick="filterTable('LOW RISK',this)">🟢 Low Risk</button>
      <button class="filt f-ben" onclick="filterTable('BENEFICIARY',this)">🔵 Beneficiary</button>
    </div>

    <!-- Main results table -->
    <div class="table-wrap">
      <table id="resultsTable">
        <thead>
          <tr>
            <th>#</th>
            <th>Symbol</th>
            <th>Company</th>
            <th>Industry</th>
            <th class="c">Wt%</th>
            <th class="c">F1<br>Direct</th>
            <th class="c">F2<br>Supply</th>
            <th class="c">F3<br>Macro</th>
            <th class="c">Overall</th>
            <th class="c">Risk Band</th>
            <th class="c">Status</th>
            <th>Key Risk / Opportunity</th>
          </tr>
        </thead>
        <tbody id="resultsBody"></tbody>
      </table>
    </div>

    <!-- Unmatched -->
    <div id="unmatched-section" style="display:none;">
      <div class="unmatched-box">
        <h3>⚠ Tickers Not Found in Database (<span id="unmatchedCount">0</span>)</h3>
        <p style="font-size:11px;color:var(--text2);margin-bottom:8px;">These symbols were in your file but not found in our Nifty 500 database. Check for typos or non-Nifty500 stocks.</p>
        <div class="unmatched-chips" id="unmatchedChips"></div>
      </div>
    </div>

  </div><!-- /results -->
</div><!-- /main -->

<footer>
  <p>
